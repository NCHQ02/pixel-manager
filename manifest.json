{
  "manifest_version": 3,
  "name": "Social Pixel Tracker (Meta & TikTok)",
  "version": "2.0.0",
  "description": "Theo dõi và hiển thị Meta (Facebook) và TikTok Pixel events.",
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "permissions": [
    "webRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "action": {
    "default_icon": "logo.png"
  }
}
